{
  "name": "@arindam923/flashdb",
  "version": "1.1.0",
  "description": "Realtime key-value database with WebSocket API and React SDK",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "database",
    "realtime",
    "websocket",
    "key-value",
    "flashdb"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arindam923/flashdb"
  }
}
